generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String              @id @default(cuid())
  name                 String?
  email                String              @unique
  password             String
  role                 String              @default("viewer")
  storageLimit         String              @default("1GB")
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  bimVersions          BimVersion[]
  calendarEvents       CalendarEvent[]
  constructionItems    ConstructionItem[]
  contacts             Contact[]
  fixedAssets          FixedAsset[]
  notifications        Notification[]
  projects             Project[]
  addedProjectContacts ProjectContact[]    @relation("AddedContacts")
  siteLogs             SiteLog[]
  supplies             Supply[]
  tasks                Task[]
  warehouseMovements   WarehouseMovement[]
  purchaseOrders       PurchaseOrder[]
  libraryFiles         LibraryFile[]
  projectDocuments     ProjectDocument[]
}

model Project {
  id                String               @id @default(cuid())
  title             String
  description       String?
  client            String?
  location          String?
  projectType       String?
  area              Float?               @default(0)
  status            String               @default("activo")
  imageUrl          String?
  startDate         DateTime?
  authorId          String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  bimBranches       BimBranch[]
  bimDocument       BimDocument?
  fixedAssets       FixedAsset[]
  inspectionRecords InspectionRecord[]
  levels            Level[]
  author            User?                @relation(fields: [authorId], references: [id])
  config            ProjectConfig?
  contacts          ProjectContact[]
  items             ProjectItem[]
  transactions      ProjectTransaction[]
  purchaseOrders    PurchaseOrder[]
  siteLogs          SiteLog[]
  supplyRequests    SupplyRequest[]
  tasks             Task[]
  movements         WarehouseMovement[]
  documents         ProjectDocument[]
  changeOrders      ProjectChangeOrder[]
  payrolls          Payroll[]
  valuations        Valuation[]
}

model ProjectConfig {
  id                 String  @id @default(cuid())
  projectId          String  @unique
  utility            Float   @default(10)
  adminExpenses      Float   @default(5)
  iva                Float   @default(13)
  it                 Float   @default(3)
  socialCharges      Float   @default(55)
  toolWear           Float   @default(3)
  exchangeRate       Float   @default(6.96)
  financing          Float   @default(0)
  guaranteeRetention Float   @default(7)
  mainCurrency       String? @default("BS")
  secondaryCurrency  String? @default("USD")
  workingDays        Int?    @default(6)
  project            Project @relation(fields: [projectId], references: [id])
}

model Level {
  id                String                     @id @default(cuid())
  name              String
  projectId         String
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  inspectionRecords InspectionRecord[]
  project           Project                    @relation(fields: [projectId], references: [id])
  itemQuantities    ProjectItemLevelQuantity[]
  movements         WarehouseMovement[]
}

model ConstructionItem {
  id              String                   @id @default(cuid())
  chapter         String
  description     String
  unit            String
  performance     Float                    @default(1)
  directCost      Float                    @default(0)
  total           Float                    @default(0)
  userId          String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  user            User?                    @relation(fields: [userId], references: [id])
  supplies        ConstructionItemSupply[]
  projectItems    ProjectItem[]
  qualityControls QualityControl[]
}

model Supply {
  id          String                   @id @default(cuid())
  typology    String
  description String
  unit        String
  price       Float                    @default(0)
  tag         String?
  userId      String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  itemUsage   ConstructionItemSupply[]
  poItems     PurchaseOrderItem[]
  user        User?                    @relation(fields: [userId], references: [id])
  costs       SupplyCost[]
  requests    SupplyRequest[]
  movements   WarehouseMovement[]
}

model SupplyCost {
  id          String   @id @default(cuid())
  supplyId    String
  supplierId  String
  price       Float
  date        DateTime @default(now())
  isPreferred Boolean  @default(false)
  notes       String?
  supplier    Contact  @relation(fields: [supplierId], references: [id])
  supply      Supply   @relation(fields: [supplyId], references: [id])
}

model ConstructionItemSupply {
  id       String           @id @default(cuid())
  itemId   String
  supplyId String
  quantity Float            @default(0)
  item     ConstructionItem @relation(fields: [itemId], references: [id])
  supply   Supply           @relation(fields: [supplyId], references: [id])
}

model ProjectItem {
  id                String                     @id @default(cuid())
  projectId         String
  itemId            String
  quantity          Float                      @default(0)
  progress          Float                      @default(0)
  performance       Float?                     // Override for construction performance
  extraDays         Int                        @default(0)
  ganttStatus       String                     @default("no iniciado")
  inspectionRecords InspectionRecord[]
  item              ConstructionItem           @relation(fields: [itemId], references: [id])
  project           Project                    @relation(fields: [projectId], references: [id])
  levelQuantities   ProjectItemLevelQuantity[]
  movements         WarehouseMovement[]
  valuations        ValuationItem[]
  predecessorId     String?
  startDate         DateTime?
  predecessor       ProjectItem?               @relation("ItemDependencies", fields: [predecessorId], references: [id])
  successors        ProjectItem[]              @relation("ItemDependencies")

  @@unique([projectId, itemId])
}

model ProjectItemLevelQuantity {
  id            String      @id @default(cuid())
  projectItemId String
  levelId       String
  quantity      Float       @default(0)
  level         Level       @relation(fields: [levelId], references: [id])
  projectItem   ProjectItem @relation(fields: [projectItemId], references: [id], onDelete: Cascade)

  @@unique([projectItemId, levelId])
}

model ProjectContact {
  id          String  @id @default(cuid())
  projectId   String
  contactId   String
  addedById   String?
  permissions Json?   @default("{}")
  addedBy     User?   @relation("AddedContacts", fields: [addedById], references: [id])
  contact     Contact @relation(fields: [contactId], references: [id])
  project     Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, contactId])
}

model ProjectTransaction {
  id          String   @id @default(cuid())
  projectId   String
  amount      Float
  type        String
  category    String
  description String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  payrollId   String?  @unique
  payroll     Payroll? @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id])
}

model SiteLog {
  id        String   @id @default(cuid())
  projectId String
  authorId  String
  type      String
  content   String
  date      DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  number      String              @unique
  projectId   String
  authorId    String?
  supplierId  String?
  notes        String?
  totalAmount Float               @default(0)
  status      String              @default("pendiente")
  paymentType String              @default("contado")
  dueDate     DateTime?
  date        DateTime            @default(now())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  project     Project             @relation(fields: [projectId], references: [id])
  author      User?               @relation(fields: [authorId], references: [id])
  supplier    Contact?            @relation(fields: [supplierId], references: [id])
  items       PurchaseOrderItem[]
  movements   WarehouseMovement[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  supplyId        String
  quantity        Float         @default(0)
  price           Float         @default(0)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  supply          Supply        @relation(fields: [supplyId], references: [id])
}

model WarehouseMovement {
  id              String         @id @default(cuid())
  type            String
  quantity        Float
  notes           String?
  projectId       String
  supplyId        String
  purchaseOrderId String?
  itemId          String?
  levelId         String?
  createdAt       DateTime       @default(now())
  authorId        String?
  author          User?          @relation(fields: [authorId], references: [id])
  projectItem     ProjectItem?   @relation(fields: [itemId], references: [id])
  level           Level?         @relation(fields: [levelId], references: [id])
  project         Project        @relation(fields: [projectId], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supply          Supply         @relation(fields: [supplyId], references: [id])
}

model SupplyRequest {
  id        String   @id @default(cuid())
  projectId String
  supplyId  String
  quantity  Float
  status    String   @default("pendiente")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id])
  supply    Supply   @relation(fields: [supplyId], references: [id])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("pendiente")
  priority    String    @default("media")
  dueDate     DateTime?
  assignee    String?
  projectId   String?
  userId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project?  @relation(fields: [projectId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])
}

model Contact {
  id             String           @id @default(cuid())
  name           String
  email          String?
  phone          String
  type           String           @default("cliente")
  status         String           @default("active")
  company        String?
  nit            String?
  address        String?
  notes          String?
  userId         String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  bankAccounts   BankAccount[]
  user           User?            @relation(fields: [userId], references: [id])
  projects       ProjectContact[]
  purchaseOrders PurchaseOrder[]
  supplyCosts    SupplyCost[]
  contactDocuments ContactDocument[]
  payrollEntries   PayrollEntry[]
}

model BankAccount {
  id            String   @id @default(cuid())
  contactId     String
  bankName      String
  accountNumber String
  swiftCode     String?
  isPreferred   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contact       Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model FixedAsset {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  brand         String?
  model         String?
  serialNumber  String?
  purchasePrice Float    @default(0)
  purchaseDate  DateTime
  location      String?
  status        String   @default("disponible")
  userId        String?
  projectId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  authorId      String?
  author        User?    @relation(fields: [authorId], references: [id])
  project       Project? @relation(fields: [projectId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model QualityControl {
  id          String                   @id @default(cuid())
  description String
  itemId      String
  item        ConstructionItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  subPoints   QualityControlSubPoint[]
}

model QualityControlSubPoint {
  id               String         @id @default(cuid())
  description      String
  qualityControlId String
  qualityControl   QualityControl @relation(fields: [qualityControlId], references: [id], onDelete: Cascade)
}

model BimDocument {
  id        String     @id @default(cuid())
  projectId String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  project   Project    @relation(fields: [projectId], references: [id])
  topics    BimTopic[]
}

model BimTopic {
  id         String      @id @default(cuid())
  documentId String
  parentId   String?
  title      String
  content    String?
  order      Int         @default(0)
  status     String      @default("in_progress")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  document   BimDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  parent     BimTopic?   @relation("TopicHierarchy", fields: [parentId], references: [id])
  children   BimTopic[]  @relation("TopicHierarchy")
}

model Unit {
  id           String   @id @default(cuid())
  name         String
  abbreviation String
  magnitude    String
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Chapter {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  type        String   @default("reunion")
  project     String?
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model BimBranch {
  id        String       @id @default(cuid())
  projectId String
  name      String
  isMain    Boolean      @default(false)
  createdAt DateTime     @default(now())
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions  BimVersion[]
}

model BimVersion {
  id         String    @id @default(cuid())
  branchId   String
  authorId   String
  authorName String
  message    String
  hash       String
  createdAt  DateTime  @default(now())
  author     User      @relation(fields: [authorId], references: [id])
  branch     BimBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model InspectionRecord {
  id            String            @id @default(cuid())
  projectId     String
  projectItemId String
  levelId       String?
  inspector     String?
  date          DateTime          @default(now())
  status        String            @default("pendiente")
  notes         String?
  imageUrls     String[]          @default([])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  checks        InspectionCheck[]
  level         Level?            @relation(fields: [levelId], references: [id])
  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectItem   ProjectItem       @relation(fields: [projectItemId], references: [id], onDelete: Cascade)
}

model InspectionCheck {
  id                 String           @id @default(cuid())
  inspectionRecordId String
  qualityControlId   String
  subPointId         String?
  passed             Boolean          @default(false)
  observation        String?
  inspectionRecord   InspectionRecord @relation(fields: [inspectionRecordId], references: [id], onDelete: Cascade)
}

model ProjectDocument {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  type       String
  size       Int
  url        String
  folder     String   @default("/")
  isFolder   Boolean  @default(false)
  source     String   @default("local") // local, google_drive
  status     String   @default("uploaded")
  authorName String   @default("Usuario Bimus")
  userId     String?
  author     User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model LibraryFile {
  id          String   @id @default(cuid())
  userId      String
  r2Key       String   @unique
  name        String
  size        Int
  mimeType    String   @default("application/octet-stream")
  publicUrl   String
  category    String   @default("CAD Design")
  libraryType String   @default("cad")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactDocument {
  id        String   @id @default(cuid())
  contactId String
  r2Key     String   @unique
  name      String
  size      Int
  mimeType  String   @default("application/pdf")
  publicUrl String
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model ProjectChangeOrder {
  id          String   @id @default(cuid())
  projectId   String
  number      String?  @unique // e.g., OC-001
  description String
  type        String   @default("Adición") // Adición, Deducción, Incremento de Precio
  status      String   @default("Aprobada")
  amount      Float    @default(0)
  reason      String?  @default("Cambio de Cómputo")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Payroll {
  id           String         @id @default(cuid())
  projectId    String
  startDate    DateTime
  endDate      DateTime
  totalAmount  Float          @default(0)
  status       String         @default("completado")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entries      PayrollEntry[]
  transaction  ProjectTransaction?
}

model PayrollEntry {
  id          String   @id @default(cuid())
  payrollId   String
  contactId   String
  daysWorked  Float    @default(0)
  dailyRate   Float    @default(0)
  totalAmount Float    @default(0)
  payroll     Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  contact     Contact  @relation(fields: [contactId], references: [id])
}
model Valuation {
  id                  String          @id @default(cuid())
  projectId           String
  number              String?         @unique
  description         String?
  status              String          @default("completado")
  totalAmount         Float           @default(0)
  retentionAmount     Float           @default(0)
  retentionPercentage Float           @default(0)
  netAmount           Float           @default(0)
  date                DateTime        @default(now())
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items               ValuationItem[]
}

model ValuationItem {
  id            String      @id @default(cuid())
  valuationId   String
  projectItemId String
  quantity      Float       @default(0)
  price         Float       @default(0)
  amount        Float       @default(0)
  valuation     Valuation   @relation(fields: [valuationId], references: [id], onDelete: Cascade)
  projectItem   ProjectItem @relation(fields: [projectItemId], references: [id])
}
